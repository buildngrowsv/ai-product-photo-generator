# Required — set these before deploying

# fal.ai API key for product photo generation
FAL_KEY=

# --- Upstash Redis — Pro token store + server-side rate limits (T018) ---
# Used for: (1) durable Pro entitlement tokens (productphoto:sub:token:<uuid>)
# activated by the Stripe webhook; (2) server-side IP rate limiting.
# Create at https://console.upstash.com/ → copy REST URL + token.
# If unset, Pro token bypass is disabled and all users use IP rate limiting.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_APP_URL=https://aiproductphotomaker.com
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
